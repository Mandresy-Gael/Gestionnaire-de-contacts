<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestionnaire de Contacts</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">

    <script>

        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                      
                        'nuit':    '#0D0D1A',   /* fond très sombre */
                        'marine':  '#1A1A2E',   /* fond des cartes */
                        'or':      '#C9A96E',   /* couleur accent dorée */
                        'creme':   '#E8E0D0',   /* texte principal doux */
                        'blanc':   '#FFFFFF',   /* blanc pur pour les titres */
                    },
                    fontFamily: {
                        /* Cormorant : pour les grands titres */
                        'titre':    ['"Cormorant Garamond"', 'serif'],
                        /* DM Sans : pour le texte courant et les boutons */
                        'corps':    ['"DM Sans"', 'sans-serif'],
                        /* Space Grotesk : pour les badges, codes, accents */
                        'accent':   ['"Space Grotesk"', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <style>
        
        body {
            background-color: #0D0D1A;
            background-image:
                radial-gradient(ellipse at 15% 40%, rgba(201, 169, 110, 0.06) 0%, transparent 55%),
                radial-gradient(ellipse at 85% 15%, rgba(201, 169, 110, 0.04) 0%, transparent 50%);
            background-attachment: fixed;
        }

      
        .glass {
            background: rgba(26, 26, 46, 0.75);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
        }

     
        input:focus, select:focus {
            outline: none;
            box-shadow: 0 0 0 2px rgba(201, 169, 110, 0.35);
        }

        /* Animation : le tableau monte doucement quand la page se charge */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-up { animation: fadeUp 0.5s ease forwards; }

        /* Chaque ligne du tableau apparaît avec un léger délai pour un effet cascade */
        .contact-row { animation: fadeUp 0.4s ease forwards; opacity: 0; }
        .contact-row:nth-child(1)  { animation-delay: 0.05s; }
        .contact-row:nth-child(2)  { animation-delay: 0.10s; }
        .contact-row:nth-child(3)  { animation-delay: 0.15s; }
        .contact-row:nth-child(4)  { animation-delay: 0.20s; }
        .contact-row:nth-child(5)  { animation-delay: 0.25s; }
        .contact-row:nth-child(6)  { animation-delay: 0.30s; }
        .contact-row:nth-child(7)  { animation-delay: 0.35s; }
        .contact-row:nth-child(8)  { animation-delay: 0.40s; }
        .contact-row:nth-child(9)  { animation-delay: 0.45s; }
        .contact-row:nth-child(10) { animation-delay: 0.50s; }

        /* Couleur du texte dans les options du menu déroulant (select) */
        select option { background-color: #1A1A2E; color: #E8E0D0; }

        /* Barre de défilement personnalisée pour ne pas casser le style sombre */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track  { background: #0D0D1A; }
        ::-webkit-scrollbar-thumb  { background: #C9A96E44; border-radius: 9999px; }
    </style>
</head>
<body class="font-corps text-creme min-h-screen">

    <!-- ======================================== -->
    <!-- BARRE DE NAVIGATION (collée en haut)     -->
    <!-- ======================================== -->
    <!-- py-2.5 : padding réduit pour que le navbar reste fin et discret -->
    <nav class="glass sticky top-0 z-50 border-b border-or/10 px-6 py-3 flex items-center justify-between gap-3">

       
        <div class="flex items-center gap-2 flex-shrink-0">
            <span class="text-lg">👥</span>
            <span class="font-titre text-2xl font-semibold text-or tracking-wide">Mes Contacts</span>
        </div>

        <form action="/rechercher" method="get" class="flex gap-2 flex-1 max-w-sm">
            <input
                type="text"
                name="q"
                placeholder="🔍 Rechercher..."
                value="<%= typeof q !== 'undefined' ? q : '' %>"
                class="flex-1 px-3 py-1 rounded-lg border border-or/20 bg-nuit/60 text-creme placeholder-creme/30 font-corps text-xl transition-all duration-200 focus:border-or/60"
            >
            <button type="submit" class="px-3 py-1.5 bg-or text-nuit font-corps font-semibold text-[10px] rounded-lg hover:bg-or/80 transition-all duration-200 whitespace-nowrap">
                Rechercher
            </button>
            <a href="/contacts" class="px-3 py-1.5 border border-or/20 text-creme/60 text-[10px] rounded-lg hover:border-or/40 hover:text-creme transition-all duration-200 whitespace-nowrap">
                Effacer
            </a>
        </form>
    </nav>


    <!-- ======================================== -->
    <!-- CONTENU PRINCIPAL                        -->
    <!-- ======================================== -->
    <div class="max-w-7xl mx-auto px-6 py-10">

        <!-- Titre de la page -->
        <header class="text-center mb-10 fade-up">
            <!-- Police Cormorant pour le grand titre principal -->
            <h1 class="font-titre text-5xl font-semibold text-blanc mb-3 tracking-wide">Gestionnaire de Contacts</h1>
            <p class="text-creme/50 font-corps text-base">Organisez, ajoutez et gérez tous vos contacts en un seul endroit</p>
            <!-- Petite ligne décorative dorée sous le sous-titre -->
            <div class="mt-4 mx-auto w-16 h-px bg-or/40"></div>
        </header>

        <main class="space-y-8">

            <!-- ========================= -->
            <!-- FORMULAIRE D'AJOUT        -->
            <!-- ========================= -->
            <section class="glass border border-or/15 rounded-2xl p-8 fade-up">

                <h2 class="font-titre text-2xl text-or mb-6 flex items-center gap-2">
                    <span>✦</span> Nouveau Contact
                </h2>
                <form action="/ajouter" method="post" class="space-y-5">

                    <!-- Ligne 1 : Nom + Prénom côte à côte -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="flex flex-col gap-1.5">
                            <label for="nom" class="font-accent text-xs text-or/70 uppercase tracking-widest">Nom *</label>
                            <input type="text" id="nom" name="nom" placeholder="Ex: Dupont" required
                                   class="px-4 py-3 rounded-xl border border-or/20 bg-nuit/50 text-creme font-corps text-sm transition-all duration-200 focus:border-or/60">
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label for="prenom" class="font-accent text-xs text-or/70 uppercase tracking-widest">Prénom *</label>
                            <input type="text" id="prenom" name="prenom" placeholder="Ex: Jean" required
                                   class="px-4 py-3 rounded-xl border border-or/20 bg-nuit/50 text-creme font-corps text-sm transition-all duration-200 focus:border-or/60">
                        </div>
                    </div>

                    <!-- Ligne 2 : Téléphone + Email -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="flex flex-col gap-1.5">
                            <label for="telephone" class="font-accent text-xs text-or/70 uppercase tracking-widest">Téléphone *</label>
                            <input type="tel" id="telephone" name="telephone" placeholder="Ex: 06 12 34 56 78" required
                                   class="px-4 py-3 rounded-xl border border-or/20 bg-nuit/50 text-creme font-corps text-sm transition-all duration-200 focus:border-or/60">
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label for="email" class="font-accent text-xs text-or/70 uppercase tracking-widest">Email</label>
                            <input type="email" id="email" name="email" placeholder="Ex: jean@email.com"
                                   class="px-4 py-3 rounded-xl border border-or/20 bg-nuit/50 text-creme font-corps text-sm transition-all duration-200 focus:border-or/60">
                        </div>
                    </div>

                    <!-- Ligne 3 : Adresse + Catégorie -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="flex flex-col gap-1.5">
                            <label for="adresse" class="font-accent text-xs text-or/70 uppercase tracking-widest">Adresse</label>
                            <input type="text" id="adresse" name="adresse" placeholder="Ex: 12 Rue de la Paix, Paris"
                                   class="px-4 py-3 rounded-xl border border-or/20 bg-nuit/50 text-creme font-corps text-sm transition-all duration-200 focus:border-or/60">
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label for="categorie" class="font-accent text-xs text-or/70 uppercase tracking-widest">Catégorie</label>
                            <select id="categorie" name="categorie"
                                    class="px-4 py-3 rounded-xl border border-or/20 bg-nuit/50 text-creme font-corps text-sm transition-all duration-200 focus:border-or/60 cursor-pointer">
                                <option value="Famille">Famille</option>
                                <option value="Ami">Ami</option>
                                <option value="Collègue">Collègue</option>
                                <option value="Client">Client</option>
                                <option value="Autre">Autre</option>
                            </select>
                        </div>
                    </div>

                    <div class="pt-2">
                        <button type="submit"
                                class="inline-flex items-center gap-2 px-7 py-3 bg-or text-nuit font-corps font-semibold text-sm rounded-xl hover:bg-or/85 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-or/20 transition-all duration-200">
                            💾 Enregistrer le contact
                        </button>
                    </div>
                </form>
            </section>


            <!-- ========================= -->
            <!-- LISTE DES CONTACTS        -->
            <!-- ========================= -->
            <section class="glass border border-or/15 rounded-2xl p-8 fade-up">

                <div class="flex items-center justify-between mb-6">
                    <h2 class="font-titre text-2xl text-or flex items-center gap-2">
                        <span>✦</span> Liste des Contacts
                    </h2>
                    <span class="font-accent text-xs px-3 py-1.5 rounded-full border border-or/25 text-or/80 bg-or/10">
                        <%= resultat.length %> contact(s)
                    </span>
                </div>

                <div class="overflow-x-auto rounded-xl">
                    <table class="w-full border-collapse">
                        <thead>
                            <tr class="border-b border-or/15">
                                <th class="text-left py-3 px-4 font-accent text-xs text-or/50 uppercase tracking-widest">Nom & Prénom</th>
                                <th class="text-left py-3 px-4 font-accent text-xs text-or/50 uppercase tracking-widest">Téléphone</th>
                                <th class="text-left py-3 px-4 font-accent text-xs text-or/50 uppercase tracking-widest">Email</th>
                                <th class="text-left py-3 px-4 font-accent text-xs text-or/50 uppercase tracking-widest">Adresse</th>
                                <th class="text-left py-3 px-4 font-accent text-xs text-or/50 uppercase tracking-widest">Catégorie</th>
                                <th class="text-left py-3 px-4 font-accent text-xs text-or/50 uppercase tracking-widest">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!--
                                <% %> : exécute du code JavaScript dans la page (sans rien afficher)
                                <%= %> : affiche le résultat du code JavaScript dans la page
                                resultat : tableau de contacts envoyé depuis app.js via res.render("index", { resultat })
                            -->
                            <% if (resultat && resultat.length > 0) { %>
                                <% for(let i = 0; i < resultat.length; i++) { %>
                                    <tr class="contact-row border-b border-or/5 hover:bg-or/5 transition-colors duration-150">

                                        <!-- Colonne Nom + Avatar avec les initiales -->
                                        <td class="py-4 px-4">
                                            <div class="flex items-center gap-3">
                                                <!-- Avatar circulaire avec les 2 premières lettres du prénom et du nom -->
                                                <div class="w-10 h-10 rounded-full bg-or/20 border border-or/30 flex items-center justify-center flex-shrink-0">
                                                    <!-- .charAt(0) : récupère la première lettre, .toUpperCase() : la met en majuscule -->
                                                    <span class="font-accent text-xs font-semibold text-or">
                                                        <%= resultat[i].prenom.charAt(0).toUpperCase() %><%= resultat[i].nom.charAt(0).toUpperCase() %>
                                                    </span>
                                                </div>
                                                <span class="font-corps font-medium text-blanc text-sm">
                                                    <%= resultat[i].prenom %> <%= resultat[i].nom %>
                                                </span>
                                            </div>
                                        </td>

                                        <td class="py-4 px-4 font-corps text-sm text-creme/80">
                                            📞 <%= resultat[i].telephone %>
                                        </td>

                                        <td class="py-4 px-4 font-corps text-sm">
                                            <% if (resultat[i].email) { %>
                                                <a href="mailto:<%= resultat[i].email %>" class="text-or/70 hover:text-or transition-colors duration-150">
                                                    ✉️ <%= resultat[i].email %>
                                                </a>
                                            <% } else { %>
                                                <span class="text-creme/25">—</span>
                                            <% } %>
                                        </td>
                                        <td class="py-4 px-4 font-corps text-sm text-creme/70">
                                            <%= resultat[i].adresse || '—' %>
                                        </td>

                                        <td class="py-4 px-4">
                                            <!--
                                                Badge de couleur selon la catégorie.
                                                .toLowerCase() → minuscules (ex: "Ami" → "ami")
                                                .normalize('NFD') + replace → enlève les accents (ex: "Collègue" → "collegue")
                                                On utilise le résultat pour choisir la bonne classe de couleur
                                            -->
                                            <%
                                                let cat = resultat[i].categorie.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
                                                let badgeClass = {
                                                    'famille':  'bg-emerald-500/10 text-emerald-300 border-emerald-500/25',
                                                    'ami':      'bg-or/10 text-or border-or/25',
                                                    'collegue': 'bg-amber-500/10 text-amber-300 border-amber-500/25',
                                                    'client':   'bg-rose-500/10 text-rose-300 border-rose-500/25',
                                                    'autre':    'bg-creme/5 text-creme/50 border-creme/20',
                                                }[cat] || 'bg-creme/5 text-creme/50 border-creme/20';
                                            %>
                                            <span class="font-accent text-xs px-2.5 py-1 rounded-full border <%= badgeClass %>">
                                                <%= resultat[i].categorie %>
                                            </span>
                                        </td>

                                        <td class="py-4 px-4">
                                            <div class="flex items-center gap-2">
                                                <!-- Lien vers la page de modification du contact -->
                                                <a href="/modifier/<%= resultat[i].id %>"
                                                   class="font-corps text-xs px-3 py-1.5 rounded-lg border border-or/25 text-or/70 hover:text-or hover:border-or/50 hover:-translate-y-0.5 transition-all duration-150">
                                                    ✏️ Modifier
                                                </a>
                                                <!--
                                                    onclick="return confirm(...)" : affiche une boîte de dialogue.
                                                    Si l'utilisateur clique "Annuler" → return false → le lien n'est pas suivi.
                                                    Si l'utilisateur clique "OK" → return true → la suppression se fait.
                                                -->
                                                <a href="/supprimer/<%= resultat[i].id %>"
                                                   onclick="return confirm('Supprimer <%= resultat[i].prenom %> <%= resultat[i].nom %> ?')"
                                                   class="font-corps text-xs px-3 py-1.5 rounded-lg border border-rose-500/25 text-rose-400/70 hover:text-rose-300 hover:border-rose-400/50 hover:-translate-y-0.5 transition-all duration-150">
                                                    🗑️ Supprimer
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-20 text-creme/30">
                                        <div class="text-5xl mb-4">👤</div>
                                        <p class="font-titre text-xl text-creme/40 mb-2">Aucun contact enregistré</p>
                                        <p class="font-corps text-sm text-creme/25">Utilisez le formulaire ci-dessus pour ajouter votre premier contact.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </section>

        </main>
    </div>

</body>
</html>
